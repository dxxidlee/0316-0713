{
  "buildCommand": "cd 0316 && npm install && npm run build",
  "outputDirectory": "0316/dist",
  "functions": {
    "0316/api/upload.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/upload", "destination": "/0316/api/upload.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
